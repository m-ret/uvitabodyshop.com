# Copy to .env.local for local dev. Never commit .env*.

# Public site origin (used for sitemap.ts, llms.txt, JSON-LD canonical URLs).
NEXT_PUBLIC_SITE_URL=https://uvitabodyshop.com

# Contact endpoints echoed into the quote-request API.
NEXT_PUBLIC_WHATSAPP_NUMBER=5068769927
NEXT_PUBLIC_PHONE_NUMBER=+5068769927

# UnoSend — lead email from /api/quote-request (no-op when unset)
# https://docs.unosend.co/
# UNOSEND_API_KEY=un_xxxx
# UNOSEND_FROM=notificaciones@tudominioverificado.com

# Google Apps Script (or any) JSON webhook for lead rows — optional
# GOOGLE_SHEET_WEBHOOK_URL=

# Optional: Vercel Analytics / Speed Insights (leave unset locally)
# VERCEL_ANALYTICS_ID=
